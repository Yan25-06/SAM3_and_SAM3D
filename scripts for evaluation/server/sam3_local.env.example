# Local Ubuntu example for:
# svo@svo-B760M-GAMING-PLUS-WIFI-DDR4:~/Downloads/sam3$
#
# Copy:
#   cp scripts/server/sam3_local.env.example scripts/server/sam3_server.env

PROJECT_ROOT=${HOME}/Downloads/sam3
PYTHON_BIN=python3
VENV_DIR=${HOME}/Downloads/sam3/.venv-sam3

DATA_ROOT=${HOME}/Downloads/sam3/data
OUT_ROOT=${HOME}/Downloads/sam3/outputs
CACHE_ROOT=${HOME}/Downloads/sam3/.cache

HF_HOME=${HOME}/Downloads/sam3/.cache/huggingface
HF_MODEL_REPO=facebook/sam3
HF_TOKEN=

ODINW_ROOT=${HOME}/Downloads/sam3/data/odinw13
RF100_ROOT=${HOME}/Downloads/sam3/data/rf100-vl
CHECKPOINT_PATH=${HOME}/Downloads/sam3/checkpoints/sam3.pt

PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cu128

NUM_GPUS=1
NUM_WORKERS=4
TRAIN_WORKERS=4
VAL_BATCH_SIZE=1
TRAIN_BATCH_SIZE=1
SAM3_RESOLUTION=1008
GATHER_PRED_VIA_FILESYS=false
AUTO_DOWNLOAD_RF100=false
