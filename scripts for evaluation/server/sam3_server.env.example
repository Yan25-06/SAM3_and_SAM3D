# Copy this file to scripts/server/sam3_server.env and edit the values.

PROJECT_ROOT=/workspace/sam3
PYTHON_BIN=python3.12
VENV_DIR=/workspace/sam3/.venv-sam3

DATA_ROOT=/workspace/data
OUT_ROOT=/workspace/outputs/sam3
CACHE_ROOT=/workspace/cache

HF_HOME=/workspace/cache/huggingface
HF_MODEL_REPO=facebook/sam3
HF_TOKEN=

ODINW_ROOT=/workspace/data/odinw13
RF100_ROOT=/workspace/data/rf100-vl
CHECKPOINT_PATH=/workspace/sam3/checkpoints/sam3.pt

PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cu128

NUM_GPUS=1
NUM_WORKERS=4
TRAIN_WORKERS=4
VAL_BATCH_SIZE=1
TRAIN_BATCH_SIZE=1
SAM3_RESOLUTION=1008
GATHER_PRED_VIA_FILESYS=false
AUTO_DOWNLOAD_RF100=false
